# ===========================================
# CultScreener API Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===========================================
# Database (Required)
# ===========================================
DATABASE_URL=postgresql://user:password@host:5432/cultscreener

# ===========================================
# Redis (Required for job queue)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# API Keys
# ===========================================

# Helius RPC (Required for holder analysis)
HELIUS_API_KEY=your_helius_api_key_here

# CoinGecko Pro API (Optional - for higher GeckoTerminal rate limits)
# COINGECKO_API_KEY=your_coingecko_pro_api_key_here

# ===========================================
# Admin
# ===========================================

# Password for managing curated tokens
ADMIN_PASSWORD=your_admin_password_here

# Cookie signing secret
COOKIE_SECRET=your_cookie_secret_here

# ===========================================
# Server Configuration
# ===========================================

PORT=3000
NODE_ENV=development

# CORS - comma-separated origins allowed
CORS_ORIGIN=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500

# ===========================================
# Rate Limiting
# ===========================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# Cache Settings
# ===========================================

CACHE_TOKEN_TTL=300
CACHE_PRICE_TTL=60

# ===========================================
# Database Pool (Optional - defaults shown)
# ===========================================
# DB_POOL_MAX=20
# DB_POOL_MIN=2
# DB_SSL_REJECT_UNAUTHORIZED=false

# ===========================================
# Worker (Optional - defaults shown)
# ===========================================
# WORKER_CONCURRENCY=10
# WORKER_LIMITER_MAX=10

# ===========================================
# Telegram Bot (Optional)
# ===========================================

# Token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Base URL for the API (defaults to http://localhost:3000)
# API_BASE_URL=https://cultscreener-api.onrender.com

# ===========================================
# Additional API Keys (Optional)
# ===========================================
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_key
# JUPITER_API_KEY=your_jupiter_api_key

# ===========================================
# Advanced Tuning (Optional - defaults shown)
# ===========================================
# REQUEST_TIMEOUT_MS=30000
# VIEW_BUFFER_MAX_SIZE=500
# VIEW_FLUSH_INTERVAL_MS=30000
# API_QUEUE_MAX_SIZE=100
# API_QUEUE_TIMEOUT_MS=30000
