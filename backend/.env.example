# ===========================================
# CultScreener API Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# ===========================================
# Database (Required)
# ===========================================
DATABASE_URL=postgresql://user:password@host:5432/cultscreener

# ===========================================
# Redis (Required for job queue)
# ===========================================
# REDIS_URL=redis://localhost:6379

# ===========================================
# API Keys
# ===========================================

# Helius RPC (Required for holder analysis)
HELIUS_API_KEY=your_helius_api_key_here

# CoinGecko Pro API (Optional - for higher GeckoTerminal rate limits)
# COINGECKO_API_KEY=your_coingecko_pro_api_key_here

# Solscan Pro API (Required for accurate holder counts)
SOLSCAN_API_KEY=your_solscan_api_key_here

# ===========================================
# Admin
# ===========================================

# Password for managing curated tokens
ADMIN_PASSWORD=your_admin_password_here

# Cookie signing secret
COOKIE_SECRET=your_cookie_secret_here

# ===========================================
# Server Configuration
# ===========================================

PORT=3000
NODE_ENV=development

# CORS - comma-separated origins allowed
CORS_ORIGIN=http://localhost:5500,http://localhost:3000,http://127.0.0.1:5500

# ===========================================
# Rate Limiting
# ===========================================

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_STRICT_MAX=20

# ===========================================
# Cache Settings
# ===========================================

CACHE_TOKEN_TTL=300
CACHE_PRICE_TTL=60
